<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".ui.contact.ContactFragment">

    <!-- 서브타이틀 -->
    <TextView
        android:id="@+id/tvContactSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/contact_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 구분선 -->
    <View
        android:id="@+id/dividerContact"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tvContactSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 빈 상태 안내 -->
    <TextView
        android:id="@+id/tvContactEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/contact_empty"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/dividerContact"
        app:layout_constraintBottom_toTopOf="@id/fabAddContact"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 연락처 카드 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/dividerContact"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_contact_card" />

    <!-- 임시 SMS 발송 버튼 -->
    <Button
        android:id="@+id/btnSendContacts"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="80dp"
        android:text="발송"
        android:textSize="15sp"
        android:backgroundTint="@color/alert_red"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- + FAB 버튼 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddContact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/contact_add"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/accent_primary"
        app:tint="@color/text_primary"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>