<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    tools:context=".ui.massager.MassagerFragment">

    <!-- 서브타이틀 -->
    <TextView
        android:id="@+id/tvMassagerSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/massager_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp" />

    <!-- 구분선 -->
    <View
        android:id="@+id/dividerMassager"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

    <!-- 중앙 컨텐츠 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMassager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <!-- 단계 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="현재 설정 단계"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <!-- 단계 숫자 -->
            <TextView
                android:id="@+id/tvMassageStage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_primary"
                android:textSize="64sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingExtra="0dp"
                tools:text="3" />

            <!-- 단위 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/massager_stage_unit"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="-4dp"
                android:layout_marginBottom="16dp" />

            <!-- 진행 바 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/progressTrack"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_progress_track"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_progress_fill"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 단계 점 -->
            <LinearLayout
                android:id="@+id/layoutStepDots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- - / + 버튼 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnDecrease"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="−"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card_elevated"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/tvStageRange"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    tools:text="3 / 5" />

                <Button
                    android:id="@+id/btnIncrease"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="+"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card_elevated"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 저장 버튼 -->
    <Button
        android:id="@+id/btnSaveMassager"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="72dp"
        android:text="@string/massager_save"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="@color/accent_primary"
        android:textColor="@color/text_primary" />

</LinearLayout>